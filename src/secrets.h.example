// secrets.h.example — copy to src/secrets.h (which is git-ignored) and fill in
// for LOCAL DEVELOPMENT. Lets a fresh device, or the live Wokwi sim, boot with
// credentials baked in instead of typing them into the web /config form each
// time.
//
//   cp src/secrets.h.example src/secrets.h    # then uncomment + fill the lines
//
// These only SEED EMPTY credential slots: anything you set via the web /config
// form or the captive portal (stored in NVS) always takes precedence. src/secrets.h
// is git-ignored — never commit real keys.
//
// Note on the build envs:
//   * cyd      (hardware)      — seeds a factory-fresh device; web /config still wins.
//   * wokwi    (live sim)      — seeds creds so no web typing; BUT fetching live data
//                                still needs the PAID Wokwi Private IoT Gateway.
//   * emulator (FAKE_DATA)     — ignores these entirely; it uses scripted data and has
//                                no network, so no credentials are needed or used.
#pragma once

// Subscription (USAGE page). From ~/.claude/.credentials.json -> claudeAiOauth
// (accessToken / refreshToken), or the macOS Keychain item "Claude Code-credentials".
// #define DEV_OAUTH_AT  "sk-ant-oat01-..."
// #define DEV_OAUTH_RT  "sk-ant-ort01-..."

// Admin key (COST / MODELS / TREND pages). A distinct sk-ant-admin01-… key from
// platform.claude.com -> Settings -> Admin keys (needs an org admin role).
// #define DEV_ADMIN_KEY "sk-ant-admin01-..."

// Optional POSIX timezone (otherwise stays UTC until set via /config).
// #define DEV_TZ        "EST5EDT,M3.2.0,M11.1.0"
